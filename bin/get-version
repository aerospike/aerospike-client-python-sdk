#!/usr/bin/env bash
# Print the package version from the VERSION file.
#
# VERSION is the single source of truth for PSDK's version. pyproject.toml
# reads it via [tool.setuptools.dynamic] version = {file = "VERSION"}.
#
# Output: bare version string. The VERSION file may have trailing whitespace;
# this script trims it.
# Example: 0.1.0-alpha.1

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
version_file="${repo_root}/VERSION"

if [[ ! -f "${version_file}" ]]; then
    echo "error: ${version_file} not found" >&2
    exit 1
fi

version="$(tr -d '[:space:]' < "${version_file}")"

if [[ -z "${version}" ]]; then
    echo "error: ${version_file} is empty" >&2
    exit 1
fi

printf '%s\n' "${version}"
