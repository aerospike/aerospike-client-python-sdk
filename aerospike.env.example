# Committed baseline for machines without a private env file.
#
# Local override: copy this file to `aerospike.env` (gitignored) and edit. Pytest
# loads only `aerospike.env` when it exists (those values win). If `aerospike.env`
# is missing, pytest loads this file for variables not already set in the process
# environment (CI deletes `aerospike.env` and may set vars in the workflow).
#
# Regular Aerospike server - basic data operations, no security or TLS
# Use 127.0.0.1 to avoid localhost resolving to IPv6 (::1) when server listens on IPv4
export AEROSPIKE_HOST=127.0.0.1:3100

# Optional second seed for SC / MRT / durable-delete integration tests only.
# When set, those suites connect here; general tests keep using AEROSPIKE_HOST.
# export AEROSPIKE_HOST_SC=127.0.0.1:3106

# Use services-alternate for cluster discovery (required for Docker / many setups)
export AEROSPIKE_USE_SERVICES_ALTERNATE=true

# Security-enabled Aerospike server - user/role management, authentication, privileges
export AEROSPIKE_HOST_SEC=localhost:3109

# Authentication credentials for the SC and SEC seeds only — applied by
# ``client_policy_sc`` / ``client_policy_sec`` fixtures. The default
# ``client_policy`` (used by ``AEROSPIKE_HOST``) ignores these so the AP
# cluster does not pay the auth-handshake cost on every connect.
# export AEROSPIKE_AUTH_MODE=INTERNAL
# export AEROSPIKE_AUTH_USER=admin
# export AEROSPIKE_AUTH_PASSWORD=admin

# 8.1.2+ Aerospike server, used by integration tests that exercise features
# gated on server >= 8.1.2 (ops projection extended reads, enhanced expression
# API, etc.). Tests skip cleanly when this is unset or unreachable. Set to a
# different seed than AEROSPIKE_HOST when you want to exercise pre-8.1.2
# behavior on AEROSPIKE_HOST and 8.1.2+ behavior here at the same time.
# export AEROSPIKE_HOST_8_1_2=127.0.0.1:3109

# TLS-enabled Aerospike server - encrypted connections, basic data operations
# Must match server tls-name for cert validation
export AEROSPIKE_HOST_TLS=localhost:3103
export AEROSPIKE_TLS_NAME=tls1
export AEROSPIKE_TLS_CA_FILE=/path/to/cacert.pem
export AEROSPIKE_TLS_CLIENT_CERT_FILE=/path/to/cert.pem
export AEROSPIKE_TLS_CLIENT_KEY_FILE=/path/to/key.pem

# Strong-consistency (SC) namespace for MRT / durable-delete integration tests.
# Leave unset to auto-select when the cluster has exactly one SC namespace.
# If several namespaces are SC, set this to the one you want.
# An old export for ``test_sc`` against an AP-only cluster causes confusing skips;
# remove it from aerospike.env if you rely on auto-select or only have ``test``.
# To pin a name explicitly (e.g. CI), uncomment and edit:
# export AEROSPIKE_SC_NAMESPACE=test_sc

# Logging — set to DEBUG, INFO, WARNING, etc. to enable Aerospike client logging
# (all layers: Rust core, PAC, PFC). Omit or leave blank to disable.
# export AEROSPIKE_LOG_LEVEL=DEBUG

# Optional log file path. When set, logs write to this file instead of stderr.
# export AEROSPIKE_LOG_FILE=/tmp/aerospike.log

# Benchmark comparison paths — used by `make bench-compare` / benchmarks.compare.
# Set these to your local clones; the compare tool uses them to invoke the PAC
# and legacy benchmarks as subprocesses.
# export PAC_PATH=~/tmp/aerospike-client-python-async
# export LEGACY_CLIENT_PATH=~/code/aerospike-client-python
